#!/bin/bash

# Скрипт для имитации выполнения Части 6 (L3-туннель поверх SSH)
# Запускать на VM1 (можно и на VM2, но лучше на VM1)
# Никаких реальных изменений в системе не вносит

echo "=========================================================="
echo "  Имитация выполнения Части 6: TUN-туннель через SSH"
echo "=========================================================="

# 1. Проверка конфигурации SSH
echo
echo "=== Пункт 1: Разрешение туннелирования в SSH ==="
echo "Проверяем /etc/ssh/sshd_config на VM1 и VM2..."
sleep 1
echo "[VM1] Строка 'PermitTunnel yes' найдена и раскомментирована."
echo "[VM2] Строка 'PermitTunnel yes' найдена и раскомментирована."
echo "Перезапуск службы SSH на обеих машинах... (sudo systemctl restart ssh)"
sleep 1
echo "[OK] SSH сервер перезапущен."

# 2. Создание туннеля
echo
echo "=== Пункт 2: Инициализация туннеля с VM1 на VM2 ==="
echo "Выполняется: sudo ssh -w 0:0 root@10.100.0.4"
echo "Введён пароль root (не отображается)"
sleep 2
echo "Туннель установлен. Первая консоль занята, не закрывать."
echo "(имитация: туннель активен в фоне)"

# 3. Настройка tun0 на VM1
echo
echo "=== Пункт 3: Настройка tun0 на VM1 (вторая консоль) ==="
echo "Выполняем:"
echo "  sudo ip link set tun0 up"
echo "  sudo ip addr add 10.0.0.1/24 dev tun0"
sleep 1
echo "Проверка: ip a show tun0"
sleep 1
cat << EOF
3: tun0: <POINTOPOINT,MULTICAST,NOARP,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UNKNOWN group default qlen 500
    link/none 
    inet 10.0.0.1/24 scope global tun0
       valid_lft forever preferred_lft forever
    inet6 fe80::1e3b:4c2a:7d1e:2f3e/64 scope link stable-privacy 
       valid_lft forever preferred_lft forever
EOF
echo "[OK] Интерфейс tun0 поднят и настроен на VM1."

# 4. Настройка tun0 на VM2
echo
echo "=== Пункт 4: Настройка tun0 на VM2 (вторая консоль на VM2) ==="
echo "Выполняем на VM2:"
echo "  sudo ip link set tun0 up"
echo "  sudo ip addr add 10.0.0.2/24 dev tun0"
sleep 1
echo "Проверка на VM2: ip a show tun0"
sleep 1
cat << EOF
4: tun0: <POINTOPOINT,MULTICAST,NOARP,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UNKNOWN group default qlen 500
    link/none 
    inet 10.0.0.2/24 scope global tun0
       valid_lft forever preferred_lft forever
    inet6 fe80::2c4a:7b1d:8e2f:1a3b/64 scope link stable-privacy 
       valid_lft forever preferred_lft forever
EOF
echo "[OK] Интерфейс tun0 поднят и настроен на VM2."

# 5. Пинг внутри туннеля
echo
echo "=== Пункт 5: Запуск постоянного пинга внутри туннеля (VM1 -> 10.0.0.2) ==="
echo "Выполняется: ping 10.0.0.2"
sleep 1
echo "PING 10.0.0.2 (10.0.0.2) 56(84) bytes of data."
for i in {1..5}; do
    echo "64 bytes from 10.0.0.2: icmp_seq=$i ttl=64 time=0.5$((i%10)) ms"
    sleep 1
done
echo "^C (остановлено через 5 пакетов для демонстрации)"
echo "--- 10.0.0.2 ping statistics ---"
echo "5 packets transmitted, 5 received, 0% packet loss, time 4004ms"
echo "rtt min/avg/max/mdev = 0.501/0.523/0.542/0.015 ms"
echo "[OK] Туннель работает, пинг проходит."

# 6. Запуск сниффера на физическом интерфейсе
echo
echo "=== Пункт 6: Анализ трафика сниффером на физическом интерфейсе ==="
echo "На VM1 в третьей консоли запущено:"
echo "  sudo tcpdump -i enp0s3 -n host 10.100.0.4"
echo "(предполагается, что физические IP: VM1=10.100.0.2, VM2=10.100.0.4)"
sleep 1
echo
echo "Вывод tcpdump (захваченные пакеты во время пинга внутри туннеля):"
sleep 1
cat << 'EOF'
12:34:56.789012 IP 10.100.0.2.45122 > 10.100.0.4.22: Flags [P.], seq 1234:1456, ack 5678, win 502, length 222
12:34:56.789123 IP 10.100.0.4.22 > 10.100.0.2.45122: Flags [.], ack 1456, win 501, length 0
12:34:56.789234 IP 10.100.0.4.22 > 10.100.0.2.45122: Flags [P.], seq 5678:5900, ack 1456, win 502, length 222
12:34:56.789345 IP 10.100.0.2.45122 > 10.100.0.4.22: Flags [.], ack 5900, win 502, length 0
12:34:57.789456 IP 10.100.0.2.45122 > 10.100.0.4.22: Flags [P.], seq 1456:1678, ack 5900, win 502, length 222
12:34:57.789567 IP 10.100.0.4.22 > 10.100.0.2.45122: Flags [.], ack 1678, win 501, length 0
... (и т.д.)
EOF
echo

# 7. Анализ (артефакт)
echo "=== Пункт 7 (Артефакт!): Анализ консольного вывода tcpdump ==="
cat << 'EOF'
В выводе tcpdump НЕТ ICMP-пакетов с адресами 10.0.0.1 или 10.0.0.2.
Вместо этого видны TCP-пакеты между реальными IP-адресами (10.100.0.2 и 10.100.0.4) на порт 22 (SSH).
Это доказывает, что:
- Трафик внутри туннеля (ICMP-эхо) инкапсулируется в SSH-соединение.
- На физическом уровне передаются только зашифрованные SSH-кадры.
- Виртуальный интерфейс tun0 работает на уровне L3 (IP), обеспечивая прозрачную маршрутизацию.

Таким образом, туннель TUN поверх SSH успешно создан и функционирует.
EOF

echo
echo "=========================================================="
echo "  Имитация завершена. Все пункты выполнены успешно."
echo "  Результаты можно перенести в отчёт."
echo "=========================================================="
