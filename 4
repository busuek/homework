import 'dart:async';
import 'package:flutter/material.dart';
import '../models/tetris_game.dart';
import '../widgets/game_grid.dart';
import '../widgets/control_buttons.dart';
import '../services/firebase_service.dart';
import 'game_over_screen.dart';

class GameScreen extends StatefulWidget {
  const GameScreen({Key? key}) : super(key: key);

  @override
  State<GameScreen> createState() => _GameScreenState();
}

class _GameScreenState extends State<GameScreen> {
  late TetrisGame _game;
  late FirebaseService _firebaseService;
  int _currentHighScore = 0;
  Timer? _timer;
  bool _isInitialized = false;

  @override
  void initState() {
    super.initState();
    _firebaseService = FirebaseService();
    _initializeGame();
  }

  @override
  void dispose() {
    _timer?.cancel();
    super.dispose();
  }

  void _initializeGame() async {
    _game = TetrisGame.empty();
    _currentHighScore = await _firebaseService.getGlobalHighScore();
    _startTimer();
    setState(() {
      _isInitialized = true;
    });
  }

  void _startTimer() {
    _timer?.cancel();
    _timer = Timer.periodic(const Duration(milliseconds: 500), (timer) {
      if (_game.isPaused || _game.isGameOver) return;
      _game.drop();
      if (_game.isGameOver) {
        _timer?.cancel();
        _gameOver();
      }
      if (mounted) setState(() {});
    });
  }

  void _moveLeft() {
    if (_game.isPaused || _game.isGameOver) return;
    setState(() {
      _game.moveLeft();
    });
  }

  void _moveRight() {
    if (_game.isPaused || _game.isGameOver) return;
    setState(() {
      _game.moveRight();
    });
  }

  void _rotate() {
    if (_game.isPaused || _game.isGameOver) return;
    setState(() {
      _game.rotate();
    });
  }

  void _fastDrop() {
    if (_game.isPaused || _game.isGameOver) return;
    setState(() {
      _game.hardDrop();
      if (_game.isGameOver) {
        _timer?.cancel();
        _gameOver();
      }
    });
  }

  void _pauseAndSave() async {
    setState(() {
      _game.isPaused = !_game.isPaused;
    });
    await _firebaseService.saveGame(_game);
    if (mounted) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text(_game.isPaused ? 'Game paused and saved' : 'Game resumed')),
      );
    }
  }

  void _gameOver() async {
    _timer?.cancel();
    await _firebaseService.saveScore(_game.score);
    if (!mounted) return;
    Navigator.pushReplacement(
      context,
      MaterialPageRoute(
        builder: (context) => GameOverScreen(score: _game.score),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    if (!_isInitialized) {
      return const Scaffold(
        backgroundColor: Colors.black,
        body: Center(
          child: CircularProgressIndicator(),
        ),
      );
    }

    Color scoreColor = _game.score > _currentHighScore ? Colors.amber : Colors.white;

    return Scaffold(
      backgroundColor: Colors.black,
      appBar: AppBar(
        title: const Text('Tetris Cloud'),
        backgroundColor: Colors.black,
        centerTitle: true,
      ),
      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Container(
              padding: const EdgeInsets.all(16),
              child: Row(
                mainAxisAlignment: MainAxisAlignment.spaceAround,
                children: [
                  Column(
                    children: [
                      const Text('SCORE', style: TextStyle(color: Colors.grey)),
                      Text(
                        '${_game.score}',
                        style: TextStyle(
                          color: scoreColor,
                          fontSize: 24,
                          fontWeight: FontWeight.bold,
                        ),
                      ),
                    ],
                  ),
                  Column(
                    children: [
                      const Text('HIGH SCORE', style: TextStyle(color: Colors.grey)),
                      Text(
                        '$_currentHighScore',
                        style: const TextStyle(
                          color: Colors.white,
                          fontSize: 24,
                          fontWeight: FontWeight.bold,
                        ),
                      ),
                    ],
                  ),
                ],
              ),
            ),
            GameGrid(game: _game),
            const SizedBox(height: 20),
            ControlButtons(
              onLeft: _moveLeft,
              onRight: _moveRight,
              onRotate: _rotate,
              onDown: _fastDrop,
              onPause: _pauseAndSave,
            ),
            const SizedBox(height: 20),
          ],
        ),
      ),
    );
  }
}
