import 'package:flutter/material.dart';
import '../models/tetris_game.dart';

class GameGrid extends StatelessWidget {
  final TetrisGame game;

  const GameGrid({Key? key, required this.game}) : super(key: key);

  @override
  Widget build(BuildContext context) {
    // Копируем сетку
    List<List<int>> displayGrid = List.generate(20, (i) => List.from(game.grid[i]));
    
    // Накладываем текущую фигуру
    var pieceMatrix = TetrisGame.pieces[game.currentPiece['type']]![game.currentPiece['rotation']];
    int pieceX = game.currentPiece['x'];
    int pieceY = game.currentPiece['y'];
    for (int i = 0; i < pieceMatrix.length; i++) {
      for (int j = 0; j < pieceMatrix[0].length; j++) {
        if (pieceMatrix[i][j] == 1) {
          int gridX = pieceX + j;
          int gridY = pieceY + i;
          if (gridX >= 0 && gridX < 10 && gridY >= 0 && gridY < 20) {
            displayGrid[gridY][gridX] = 1;
          }
        }
      }
    }

    return LayoutBuilder(
      builder: (context, constraints) {
        // Доступная ширина и высота от родителя (Expanded)
        double maxWidth = constraints.maxWidth;
        double maxHeight = constraints.maxHeight;
        
        // Какой размер ячейки позволит поместить всю сетку
        double cellSizeByWidth = maxWidth / 10;
        double cellSizeByHeight = maxHeight / 20;
        double cellSize = cellSizeByWidth < cellSizeByHeight ? cellSizeByWidth : cellSizeByHeight;
        
        double gridWidth = cellSize * 10;
        double gridHeight = cellSize * 20;
        
        return Center(
          child: SizedBox(
            width: gridWidth,
            height: gridHeight,
            child: GridView.builder(
              physics: const NeverScrollableScrollPhysics(),
              gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
                crossAxisCount: 10,
                childAspectRatio: 1,
              ),
              itemCount: 200,
              itemBuilder: (context, index) {
                int row = index ~/ 10;
                int col = index % 10;
                bool isFilled = displayGrid[row][col] == 1;
                return Container(
                  margin: const EdgeInsets.all(1),
                  decoration: BoxDecoration(
                    color: isFilled ? Colors.blue : Colors.grey[300],
                    border: Border.all(color: Colors.grey.shade400),
                  ),
                );
              },
            ),
          ),
        );
      },
    );
  }
}
